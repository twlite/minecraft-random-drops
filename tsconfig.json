{
  "compilerOptions": {
    "target": "es2022",
    "module": "node20",
    "strict": true,
    "alwaysStrict": true,
    "strictNullChecks": true,
    "skipDefaultLibCheck": true,
    "skipLibCheck": true,
    "allowUnreachableCode": false,
    "noEmit": true,
    "declaration": false,
    "experimentalDecorators": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
